# ============================================================
# .env — Environment Variables
# ============================================================
# This file holds sensitive config that should NEVER be
# committed to Git. Add ".env" to your .gitignore file!
#
# These values are read by dotenv in db.js and index.js
# via process.env.VARIABLE_NAME
# ============================================================

# The machine where your MySQL database lives
# Use "localhost" if it's on the same computer as the API
DB_HOST=localhost

# Your MySQL username
DB_USER=root

# Your MySQL password (fill this in)
DB_PASSWORD=your_password_here

# The name of the database your colleagues create
DB_NAME=caainterns

# The port your API server runs on
PORT=3000
